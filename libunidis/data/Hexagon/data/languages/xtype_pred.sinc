            goto <end>;
        <bad>
            D2_pred = 0;
        <end>
    }
    :D2_pred" =cmpb.gtu(" S5 "," EXT_imm_5_11u ")" is imm_24_27=0b1101 & imm_23=0 & imm_21_22=0b10 & S5 & S5i & imm_13=0 & imm_12=0 & imm_5_11u & imm_3_4=0b00 & imm_2=0 & D2_pred & EXT_imm_5_11u {
        local tmp:4 = zext(S5i:1);
