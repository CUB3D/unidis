    	local tmpb:4 = &T5_pairi;
    	
    	local c0 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c1 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c2 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c3 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c4 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c5 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c6 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c7 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	
    	local res:1 = c0 || c1 || c2 || c3 || c4 || c5 || c6 || c7;
    	D2_pred = $(PTRUE) * res; 	
    }
    :D2_pred "=!any8(vcmpb.eq(" S5_pair "," T5_pair "))" is imm_23_27=0b00100 & imm_21_22=0 & S5_pair & S5_pairi & imm_13=1 & T5_pair & T5_pairi & imm_5_7=0b001 & imm_2_4=0 & D2_pred {        
        local tmpa:4 = &S5_pairi;
    	local tmpb:4 = &T5_pairi;
    	
    	local c0 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c1 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c2 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c3 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c4 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c5 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c6 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	tmpa = tmpa + 1; tmpb = tmpb + 1;
    	local c7 = (*[register]:1 tmpa) == (*[register]:1 tmpb);
    	
    	local res:1 = c0 || c1 || c2 || c3 || c4 || c5 || c6 || c7;
    	D2_pred = $(PTRUE) * (res == 0); 	
    }
}

